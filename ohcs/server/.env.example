# Copy to .env and fill what you want. Everything has a safe default; the game runs with NONE of these.
PORT=3000
PUBLIC_URL=http://localhost:3000
JWT_SECRET=change-me-to-a-long-random-string

# --- Google login (optional). Register an OAuth 2.0 Client in Google Cloud Console.
# Authorized redirect URI must be exactly GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- Image generation (host-pays). Empty => honest offline text "paintings".
IMAGE_PROVIDER=none          # none | openai
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-1-mini

# --- The machine's brain (optional). Empty => built-in house deck.
LLM_PROVIDER=none            # none | anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# --- Matchmaking knobs ---
TABLE_TARGET=4
TABLE_MIN=3
TABLE_MAX=9
QUEUE_WAIT_MS=20000
WAIT_FALLBACK=bots           # bots | small | solo
BOT_BACKFILL=true

# --- Round / heat ---
ROUNDS_BONUS=3
NAME_SECONDS=60
